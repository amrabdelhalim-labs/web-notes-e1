# Database
DATABASE_URL=mongodb://localhost:27017/mynotes

# Auth
JWT_SECRET=change_this_to_a_strong_secret

# Runtime
NODE_ENV=development
PORT=3000

# Web Push (VAPID)
# Generate fresh keys: node -e "const wp=require('web-push'); console.log(JSON.stringify(wp.generateVAPIDKeys()))"
VAPID_PUBLIC_KEY=your_vapid_public_key_here
VAPID_PRIVATE_KEY=your_vapid_private_key_here
VAPID_EMAIL=mailto:your-email@example.com

# Expose VAPID public key to the browser (prefix with NEXT_PUBLIC_)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your_vapid_public_key_here

# Set to 'false' to enable Service Worker in development (default: disabled in dev)
# NEXT_PUBLIC_SW_DISABLED=false

# Public Next.js variables
NEXT_PUBLIC_APP_NAME=ملاحظاتي
NEXT_PUBLIC_APP_URL=http://localhost:3000
