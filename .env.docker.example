# Docker runtime environment variables (copy to .env.docker if needed)

# Server
NODE_ENV=production
PORT=3000

# Database
DATABASE_URL=mongodb://mongo:27017/mynotes

# Auth
JWT_SECRET=change_this_to_a_strong_secret

# Web Push (VAPID)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your_vapid_public_key_here
VAPID_PRIVATE_KEY=your_vapid_private_key_here
VAPID_EMAIL=mailto:your-email@example.com

# Storage strategy (placeholder for local file storage deployments)
STORAGE_TYPE=local

